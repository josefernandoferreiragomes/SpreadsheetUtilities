@using Microsoft.AspNetCore.Components.Authorization
@using SpreadsheetUtility.UI.Web.Services
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">SpreadsheetUtility.UI.Web</a>
        <AuthorizeView>
            <Authorized>
                <div class="ms-auto d-flex align-items-center">
                    <span class="text-light me-3">
                        <span class="bi bi-person-circle"></span> 
                        @AuthStateProvider.GetUserEmail()
                    </span>
                    <button type="button" class="btn btn-outline-light btn-sm" @onclick="HandleLogout">
                        <span class="bi bi-box-arrow-right"></span> Logout
                    </button>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="ms-auto d-flex gap-2">
                    <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
                    <a href="/register" class="btn btn-primary btn-sm">Register</a>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable navbar-expand-xl" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                    </NavLink>
                </div>      

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="ganttGeneratorFromPaste">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Gantt Generator Paste
                    </NavLink>
                </div>

                 <div class="nav-item px-3">
                    <NavLink class="nav-link" href="ganttGeneratorFromPasteActual">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Gantt (Work In Progr.)
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="jsonGeneratorFromPaste">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> JSON Generator
                    </NavLink>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                    </NavLink>
                </div>
                <div class="nav-item px-3 text-muted">
                    <p class="small">Login to access tools</p>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private async Task HandleLogout()
    {
        AuthStateProvider.NotifyUserLogout();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}

